modules = ["nodejs-24", "python-3.11", "python3"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Face Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Face Search Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Face Service"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 artifacts/face-service/main.py"
waitForPort = 5001

[[workflows.workflow]]
name = "Face Search Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/face-search run dev"
waitForPort = 3000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "set -a && . .env && set +a && PORT=8080 FACE_SERVICE_PORT=5001 node --enable-source-maps artifacts/api-server/dist/index.mjs"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 21722
externalPort = 3001

[nix]
channel = "stable-25_05"
packages = ["oneDNN", "re2"]

[userenv]

